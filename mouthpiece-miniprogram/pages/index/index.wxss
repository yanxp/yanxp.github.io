.page {
  min-height: 100vh;
  padding: 0 32rpx 60rpx;
}

/* Hero */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
}

.badge {
  background: linear-gradient(135deg, rgba(0,180,216,0.2), rgba(114,9,183,0.2));
  border: 1px solid rgba(0,180,216,0.3);
  border-radius: 40rpx;
  padding: 8rpx 28rpx;
  font-size: 24rpx;
  color: #00b4d8;
  margin-bottom: 32rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.3;
}

.title-gradient {
  font-size: 64rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #00b4d8 0%, #7209b7 50%, #f72585 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.3;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(224,224,240,0.8);
  margin-top: 24rpx;
  text-align: center;
}

.highlight {
  color: #00b4d8;
  font-weight: 600;
}

.desc {
  font-size: 24rpx;
  color: rgba(224,224,240,0.5);
  margin-top: 12rpx;
  text-align: center;
}

/* Stats */
.stats {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin: 40rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #00b4d8, #f72585);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(224,224,240,0.5);
  margin-top: 4rpx;
}

/* Button */
.btn-start {
  background: linear-gradient(135deg, #00b4d8, #7209b7);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

.btn-start:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.tip {
  font-size: 22rpx;
  color: rgba(224,224,240,0.4);
  margin-top: 16rpx;
}

/* Section */
.section {
  margin-top: 60rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  text-align: center;
}

.section-sub {
  font-size: 24rpx;
  color: rgba(224,224,240,0.5);
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

/* Grid */
.types-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

/* Footer */
.footer {
  text-align: center;
  padding: 60rpx 0 32rpx;
  font-size: 22rpx;
  color: rgba(224,224,240,0.3);
}

.footer-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
}
