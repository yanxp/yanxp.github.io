.page {
  min-height: 100vh;
  padding: 0 32rpx 80rpx;
}

/* Header Card */
.header-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, rgba(0,180,216,0.08), rgba(114,9,183,0.08));
  border: 1px solid rgba(0,180,216,0.15);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-top: 32rpx;
}

.emoji {
  font-size: 96rpx;
  margin-bottom: 12rpx;
}

.code {
  font-size: 36rpx;
  font-weight: 800;
  color: #00b4d8;
  letter-spacing: 4rpx;
}

.name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-top: 8rpx;
}

.tagline {
  font-size: 24rpx;
  color: rgba(224,224,240,0.6);
  margin-top: 16rpx;
  text-align: center;
  font-style: italic;
}

.group-badge {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
  background: rgba(247,37,133,0.1);
  border-radius: 24rpx;
}

.group-name {
  font-size: 22rpx;
  color: #f72585;
  font-weight: 600;
  margin-right: 12rpx;
}

.group-desc {
  font-size: 22rpx;
  color: rgba(224,224,240,0.5);
}

/* Section */
.section {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  color: rgba(224,224,240,0.8);
  line-height: 1.8;
}

/* Traits */
.traits {
  display: flex;
  flex-wrap: wrap;
}

.trait-tag {
  background: rgba(0,180,216,0.12);
  border: 1px solid rgba(0,180,216,0.2);
  border-radius: 24rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #00b4d8;
  margin: 0 12rpx 12rpx 0;
}

/* Pattern */
.pattern-list {
  display: flex;
  flex-wrap: wrap;
}

.pattern-item {
  display: flex;
  align-items: center;
  margin: 0 12rpx 12rpx 0;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
}

.pattern-name {
  font-size: 24rpx;
  color: rgba(224,224,240,0.7);
  margin-right: 12rpx;
}

.pattern-level {
  font-size: 22rpx;
  font-weight: 700;
}

.pattern-level.low { color: #4cc9f0; }
.pattern-level.mid { color: #f9c74f; }
.pattern-level.high { color: #f72585; }

/* CTA */
.cta {
  margin-top: 48rpx;
}

.btn-quiz {
  width: 100%;
  background: linear-gradient(135deg, #00b4d8, #7209b7);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 0;
}
