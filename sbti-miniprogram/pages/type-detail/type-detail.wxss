.page {
  padding: 40rpx;
  padding-bottom: 80rpx;
}

.detail-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 56rpx 40rpx;
  background: linear-gradient(180deg, rgba(108,92,231,0.1) 0%, rgba(253,121,168,0.05) 100%);
  border: 1rpx solid rgba(108,92,231,0.2);
  border-radius: 32rpx;
  margin-bottom: 48rpx;
}

.dt-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.dt-code {
  font-size: 56rpx;
  font-weight: 900;
  letter-spacing: 0.05em;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #fd79a8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
}

.dt-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #e0e0f0;
  margin-bottom: 16rpx;
}

.dt-tagline {
  font-size: 26rpx;
  color: #fd79a8;
  font-style: italic;
  margin-bottom: 32rpx;
}

.divider {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #6c5ce7, #fd79a8);
  border-radius: 2rpx;
  margin-bottom: 32rpx;
}

.dt-desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: #b8b8d4;
  text-align: left;
}

.traits {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
  justify-content: center;
}

.trait-tag {
  padding: 10rpx 24rpx;
  background: rgba(108, 92, 231, 0.12);
  border: 1rpx solid rgba(108, 92, 231, 0.25);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #a29bfe;
}

.group-info {
  margin-top: 32rpx;
}

.group-label {
  font-size: 24rpx;
  color: #6c6c8a;
}

/* Start Button */
.btn-start {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #fd79a8 100%);
  border: none;
  border-radius: 100rpx;
  box-shadow: 0 16rpx 48rpx rgba(108, 92, 231, 0.4);
}

.btn-start::after {
  border: none;
}
