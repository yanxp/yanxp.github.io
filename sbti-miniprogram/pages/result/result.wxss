.page {
  padding: 40rpx;
  padding-bottom: 80rpx;
}

/* Result Card */
.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 48rpx 40rpx;
  background: linear-gradient(180deg, rgba(108,92,231,0.1) 0%, rgba(253,121,168,0.05) 100%);
  border: 1rpx solid rgba(108,92,231,0.2);
  border-radius: 32rpx;
  margin-bottom: 48rpx;
}

.result-label {
  font-size: 24rpx;
  color: #6c6c8a;
  margin-bottom: 24rpx;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.result-code {
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 0.05em;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #fd79a8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #e0e0f0;
  margin-bottom: 16rpx;
}

.result-tagline {
  font-size: 26rpx;
  color: #fd79a8;
  font-style: italic;
  margin-bottom: 24rpx;
}

.divider {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #6c5ce7, #fd79a8);
  border-radius: 2rpx;
  margin-bottom: 24rpx;
}

.result-desc {
  font-size: 28rpx;
  line-height: 1.8;
  color: #b8b8d4;
  text-align: left;
}

/* Traits */
.traits {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
  justify-content: center;
}

.trait-tag {
  padding: 10rpx 24rpx;
  background: rgba(108, 92, 231, 0.12);
  border: 1rpx solid rgba(108, 92, 231, 0.25);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #a29bfe;
}

/* Dimension Analysis */
.dimension-section {
  margin-bottom: 48rpx;
}

.dim-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
}

.dim-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dim-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
}

.dim-label {
  width: 160rpx;
  font-size: 24rpx;
  color: #b8b8d4;
  flex-shrink: 0;
}

.dim-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 20rpx;
}

.dim-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #6c5ce7, #fd79a8);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.dim-level {
  width: 48rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.dim-level-low { color: #6c5ce7; }
.dim-level-mid { color: #a29bfe; }
.dim-level-high { color: #fd79a8; }

/* Share Canvas */
.share-canvas {
  position: fixed;
  left: -9999rpx;
  width: 750rpx;
  height: 1200rpx;
}

/* Actions */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-share,
.btn-save,
.btn-retry,
.btn-home {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-share::after,
.btn-save::after,
.btn-retry::after,
.btn-home::after {
  border: none;
}

.btn-share {
  background: linear-gradient(135deg, #6c5ce7 0%, #fd79a8 100%);
  color: #ffffff;
}

.btn-save {
  background: rgba(108, 92, 231, 0.15);
  border: 1rpx solid rgba(108, 92, 231, 0.3);
  color: #a29bfe;
}

.btn-retry {
  background: rgba(255,255,255,0.06);
  color: #e0e0f0;
}

.btn-home {
  background: transparent;
  color: #6c6c8a;
}
