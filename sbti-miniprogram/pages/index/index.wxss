.page {
  padding-bottom: 60rpx;
}

/* Hero */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 80rpx 40rpx 40rpx;
}

.badge {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: rgba(108, 92, 231, 0.15);
  border: 1rpx solid rgba(108, 92, 231, 0.3);
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #a29bfe;
  margin-bottom: 40rpx;
}

.title-wrap {
  margin-bottom: 32rpx;
}

.title-line {
  display: block;
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1.2;
}

.gradient-text {
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #fd79a8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-size: 96rpx;
  letter-spacing: 0.05em;
}

.subtitle {
  font-size: 28rpx;
  line-height: 1.8;
  color: #b8b8d4;
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.accent {
  color: #fd79a8;
  font-weight: 700;
}

/* Stats */
.stats-row {
  display: flex;
  gap: 48rpx;
  margin-bottom: 48rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #fd79a8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.stat-label {
  font-size: 22rpx;
  color: #6c6c8a;
  margin-top: 6rpx;
}

/* Start Button */
.btn-start {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 480rpx;
  height: 96rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #fd79a8 100%);
  border: none;
  border-radius: 100rpx;
  box-shadow: 0 16rpx 48rpx rgba(108, 92, 231, 0.4);
  line-height: 96rpx;
}

.btn-start::after {
  border: none;
}

.note {
  font-size: 24rpx;
  color: #6c6c8a;
  margin-top: 20rpx;
}

/* Scrolling Tags */
.type-scroll {
  width: 100%;
  margin: 48rpx 0;
  white-space: nowrap;
}

.type-scroll-track {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.scroll-tag {
  display: inline-block;
  padding: 16rpx 28rpx;
  background: #14142b;
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #b8b8d4;
  white-space: nowrap;
}

/* Types Section */
.types-section {
  padding: 0 24rpx;
}

.section-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.section-sub {
  display: block;
  text-align: center;
  color: #6c6c8a;
  font-size: 26rpx;
  margin-bottom: 40rpx;
}

.types-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* Footer */
.footer {
  text-align: center;
  padding: 48rpx 24rpx;
  margin-top: 40rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.footer text {
  display: block;
  font-size: 22rpx;
  color: #6c6c8a;
  line-height: 2;
}
