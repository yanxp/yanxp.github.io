.card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 210rpx;
  height: 200rpx;
  background: #14142b;
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.card-emoji {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.card-code {
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.card-name {
  font-size: 22rpx;
  color: #6c6c8a;
}
